# Dragon's Ledger server — environment template.
# Copy to `.env` (git-ignored) and fill in real values. NEVER commit `.env`.

# Port the server listens on (behind your reverse proxy / tunnel).
PORT=8787

# Secret used to sign auth tokens (JWT). MUST be a long random string in
# production — anyone who knows it can forge logins. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
AUTH_SECRET=change-me-to-a-long-random-string

# Where the SQLite database file lives. Keep it on a persistent volume.
DB_PATH=./data/dragons-ledger.sqlite

# Allowed origins for the HTTP auth endpoints (CORS), comma-separated.
# Use your frontend origin(s) in production, e.g. https://ledger.example.com
# "*" allows any origin (acceptable on a private LAN / tunnel).
CORS_ORIGIN=*

# Username of the server owner / superadmin (case-insensitive). When THAT
# account logs in it unlocks the admin panel — view/edit/delete every campaign,
# user, and roll across the whole server. Register the account normally first.
# Leave blank to disable the admin panel entirely.
ADMIN_USERNAME=
